{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "MCP_TRANSPORT=streamable-http PYTHONPATH=/app/src /opt/venv/bin/monarch-mcp-server",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
